{
  "name": "soatbay-uz",
  "version": "0.1.0",
  "private": true,
  "description": "Soatbay / Kaska Uz — daily-work marketplace (2 Telegram bots + admin panel)",
  "license": "UNLICENSED",
  "workspaces": [
    "libs/*",
    "apps/backend",
    "apps/employer-bot",
    "apps/worker-bot",
    "apps/admin-panel"
  ],
  "scripts": {
    "build": "npm --prefix apps/backend run build && npm --prefix apps/employer-bot run build && npm --prefix apps/worker-bot run build",
    "build:admin": "npm --prefix apps/admin-panel run build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "db:generate": "prisma generate --schema libs/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema libs/database/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema libs/database/prisma/schema.prisma",
    "db:seed": "tsx libs/database/src/seed.ts",
    "db:studio": "prisma studio --schema libs/database/prisma/schema.prisma",
    "start:backend": "npm --prefix apps/backend run serve",
    "start:employer-bot": "nx serve employer-bot",
    "start:worker-bot": "nx serve worker-bot",
    "start:admin": "npm --prefix apps/admin-panel start",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "nx": "^20.3.0",
    "prisma": "^6.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.5.4"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^2.4.3",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20"
  }
}
