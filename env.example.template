# ─────────────────────────────────────────────────────────────
# Soatbay / Kaska Uz — environment variables (shablon)
# Nusxalash: cp env.example.template .env
# Haqiqiy token va parollarni faqat .env ga yozing — Git ga yuklamang.
# ─────────────────────────────────────────────────────────────

# ── Runtime ──
NODE_ENV=development

# ── Database (PostgreSQL) ──
POSTGRES_USER=soatbay
POSTGRES_PASSWORD=soatbay
POSTGRES_DB=soatbay
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://soatbay:soatbay@localhost:5432/soatbay?schema=public

# ── Redis (FSM state / cache / rate limiting) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Backend API ──
BACKEND_PORT=3000
BACKEND_GLOBAL_PREFIX=api

# ── Auth (Admin panel JWT) ──
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me-in-production

# ── Telegram bots ──
EMPLOYER_BOT_TOKEN=123456789:REPLACE_WITH_EMPLOYER_BOT_TOKEN
WORKER_BOT_TOKEN=123456789:REPLACE_WITH_WORKER_BOT_TOKEN
# Agar api.telegram.org ochilmasa (ETIMEDOUT): VPN/proxy manzili.
# TELEGRAM_PROXY=socks5://127.0.0.1:7890
EMPLOYER_BOT_PORT=3001
WORKER_BOT_PORT=3002

# Channel where approved posts are published (e.g. @Soatbay_uz or -100xxxxxxxxxx)
CHANNEL_ID=@your_channel
WORKER_BOT_USERNAME=your_worker_bot_username
ADMIN_CONTACT=@soatbay_admin
ADMIN_CONTACT_EMPLOYER=@soatbay_uz_admin

# ── Admin panel (Angular) ──
ADMIN_PANEL_PORT=4200
API_BASE_URL=http://localhost:3000/api

# ── File storage ──
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage

# ── Business defaults (can be overridden in admin Settings) ──
DEFAULT_CARD_NUMBER=8600 0000 0000 0000
DEFAULT_CARD_HOLDER=Ism Familiya
VIP_PRICE=300000
VIP_DURATION_DAYS=30
MIN_TOPUP_AMOUNT=20000
PAYMENT_CHECK_TIMEOUT_MINUTES=3
