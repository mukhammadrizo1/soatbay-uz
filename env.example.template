# ─────────────────────────────────────────────────────────────
# Soatbay / Kaska Uz — environment variables (shablon)
# Nusxalash: cp env.example.template .env
# Haqiqiy token va parollarni faqat .env ga yozing — Git ga yuklanmaydi.
# ─────────────────────────────────────────────────────────────

# ── Runtime ──
NODE_ENV=development

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://user:pass@localhost:5432/soatbay?schema=public

# ── Redis (bot sessiyalari) ──
REDIS_URL=redis://localhost:6379

# ── Backend API ──
BACKEND_PORT=3000
BACKEND_GLOBAL_PREFIX=api
# Production: admin panel domeni (vergul bilan)
# CORS_ORIGINS=https://soatbay.pages.dev,https://soatbay-admin.pages.dev

# ── Auth (Admin panel JWT) ──
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me-in-production

# ── Telegram bots ──
EMPLOYER_BOT_TOKEN=123456789:REPLACE_WITH_EMPLOYER_BOT_TOKEN
WORKER_BOT_TOKEN=123456789:REPLACE_WITH_WORKER_BOT_TOKEN
# TELEGRAM_PROXY=socks5://127.0.0.1:7890
CHANNEL_ID=@your_channel
WORKER_BOT_USERNAME=your_worker_bot_username
ADMIN_CONTACT=@soatbay_admin
ADMIN_CONTACT_EMPLOYER=@soatbay_uz_admin

# ── Admin panel (lokal dev) ──
ADMIN_PANEL_PORT=4200

# ── Business defaults (admin Settings dan ham o'zgartiriladi) ──
DEFAULT_CARD_NUMBER=8600 0000 0000 0000
DEFAULT_CARD_HOLDER=Karta egasi F.I.O.
VIP_PRICE=300000
VIP_DURATION_DAYS=30
MIN_TOPUP_AMOUNT=20000
PAYMENT_CHECK_TIMEOUT_MINUTES=3
