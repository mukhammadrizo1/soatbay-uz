{
  "name": "@soatbay/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npx tsc -p tsconfig.app.json",
    "serve": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^6.2.0",
    "@soatbay/common": "*",
    "@soatbay/database": "*",
    "@soatbay/shared-types": "*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "grammy": "^1.31.0",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.4.1",
    "node-fetch": "^2.7.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socks-proxy-agent": "^8.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node-fetch": "^2.6.12",
    "@types/passport-jwt": "^4.0.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0"
  }
}
